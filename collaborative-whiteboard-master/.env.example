# Example environment variables for the project
# Rename to .env (or use your platform's secret manager) and fill values.

# Backend (Spring Boot) - MongoDB connection string (required)
# Example: mongodb+srv://<user>:<password>@cluster0.ebbnv.mongodb.net/whiteboard?retryWrites=true&w=majority
SPRING_DATA_MONGODB_URI=mongodb+srv://ht716756_db_user:<db_password>@board.wdyywdw.mongodb.net/?appName=Board

# Docker Compose local MongoDB init (optional, used by server/docker-compose.yaml)
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# mongo-express admin (optional, used by docker-compose.yaml)
ME_CONFIG_MONGODB_ADMINUSERNAME=
ME_CONFIG_MONGODB_ADMINPASSWORD=

# Optional: Maven wrapper credentials (only if required to download wrapper artifacts)
MVNW_USERNAME=
MVNW_PASSWORD=

# Frontend: backend base URL (optional; frontend currently defaults to the Heroku URL)
# For Next.js, you may expose this as NEXT_PUBLIC_BACKEND_URL if you need it in client code.
FRONTEND_BACKEND_URL=https://collaborative-whiteboard-app.herokuapp.com
